
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_TIMEOUT=2.0

# Maximum model context window. Keep it at or below the selected model limit.
CONTEXT_LENGTH=8192

# Minimum objectivity score for accepting a user answer as a fact.
# 0 means vague or self-judging, 100 means concrete and observable.
OBJECTIVITY_THRESHOLD=45

USER_NAME=User

